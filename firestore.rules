rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny: no read or write access to any collection unless explicitly granted.

    // Users can only read/write their own data (document + all subcollections)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Partner acceptance tokens: only Cloud Functions (admin SDK) read/write here.
    // Client apps never access this collection directly.
    match /partnerInvites/{inviteId} {
      allow read: if false;
      allow write: if false;
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
